SECRET_KEY=your-django-secret-key-here
DEBUG=False

# 允許的網域（DEBUG=False 時必填，逗號分隔）
ALLOWED_HOSTS=yourdomain.railway.app,localhost
CSRF_TRUSTED_ORIGINS=https://yourdomain.railway.app

# 資料庫（Railway / Render 會自動注入 DATABASE_URL）
DATABASE_URL=postgres://user:password@host:5432/dbname

# LINE Bot（至 LINE Developers Console 取得）
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_BOT_BASIC_ID=@your-bot-basic-id

# 管理員 LINE User ID（接收審核通知）
MANAGER_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rich Menu ID（執行 python manage.py setup_richmenu 後取得）
RICHMENU_DELIVERY=richmenu-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RICHMENU_STAFF=richmenu-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 公司座標 + 有效打卡半徑（公尺）
OFFICE_LAT=24.123456
OFFICE_LNG=120.654321
OFFICE_RADIUS_METERS=100

# OpenRouteService（送貨路線優化，至 https://openrouteservice.org/ 免費申請）
ORS_API_KEY=your-openrouteservice-api-key

# RFID 打卡機 API Key
RFID_API_KEY=your-rfid-api-key
